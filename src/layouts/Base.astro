---
import "@/styles/global.css";
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Preços de cartas LigaRiftbound em tempo real" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · LigaRiftbound Price</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <header class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[var(--color-surface-2)]/90 backdrop-blur-md">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
        <a href={base} class="flex items-center gap-2.5 text-base font-bold text-white">
          <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-[var(--color-brand)] text-sm shadow-lg shadow-[var(--color-brand)]/40">
            ◆
          </span>
          <span>LigaRiftbound <span class="text-[var(--color-brand-light)]">Price</span></span>
        </a>
        <nav class="flex items-center gap-1 text-sm">
          <a
            href={base}
            class="rounded-lg px-3 py-1.5 text-[var(--color-muted)] transition-colors hover:bg-[var(--color-surface-3)] hover:text-white"
          >
            Preços
          </a>
          <a
            href={`${base}movers`}
            class="rounded-lg px-3 py-1.5 text-[var(--color-muted)] transition-colors hover:bg-[var(--color-surface-3)] hover:text-white"
          >
            Movimentos
          </a>
          <a
            href={`${base}potencial`}
            class="rounded-lg px-3 py-1.5 text-[var(--color-muted)] transition-colors hover:bg-[var(--color-surface-3)] hover:text-white"
          >
            Potencial
          </a>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-7xl px-4 py-8">
      <slot />
    </main>
    <footer class="mt-16 border-t border-[var(--color-border)] py-8 text-center text-xs text-[var(--color-muted)]">
      Dados coletados de LigaRiftbound · Atualizado diariamente · Uso não-comercial
    </footer>
  </body>
</html>
