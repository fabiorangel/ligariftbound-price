---
import Base from "@/layouts/Base.astro";
import PriceChart from "@/components/PriceChart";
import DepthChart from "@/components/DepthChart";
import { readFileSync } from "fs";
import { resolve } from "path";

export function getStaticPaths() {
  const cardsPath = resolve("public/data/cards.json");
  const cards: { code: string; slug: string; name: string }[] = JSON.parse(
    readFileSync(cardsPath, "utf-8")
  );
  return cards.map((card) => ({
    params: { code: card.code },
    props: { name: card.name, code: card.code, slug: card.slug },
  }));
}

const { code } = Astro.params;
const { name, slug } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Base title={name}>
  <PriceChart
    client:load
    code={code}
    slug={slug}
    dataUrl={`${base}data/prices/${code}.json`}
    cardsUrl={`${base}data/cards.json`}
    base={base}
  />

  <div class="mt-12">
    <h2 class="mb-4 text-lg font-bold text-white">Profundidade de preço</h2>
    <p class="mb-6 text-sm text-[var(--color-muted)]">
      Mostra o preço esperado conforme mais unidades são compradas. Curva íngreme = alto potencial de alta.
    </p>
    <DepthChart
      client:load
      dataUrl={`${base}data/depth/${code}.json`}
    />
  </div>
</Base>
