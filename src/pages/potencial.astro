---
import Base from "@/layouts/Base.astro";
import PotencialList from "@/components/PotencialList";

const base = import.meta.env.BASE_URL;
---

<Base title="Potencial" description="Cartas em valorização com potencial de alta">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-white mb-1">Cartas em alta</h1>
    <p class="text-[var(--color-muted)] text-sm">
      Em valorização nos últimos 7 dias. Clique numa carta para ver a curva de profundidade de preço.
    </p>
  </div>

  <PotencialList
    client:load
    cardsUrl={`${base}data/cards.json`}
    marketUrl={`${base}data/market/latest.json`}
    base={base}
  />
</Base>
